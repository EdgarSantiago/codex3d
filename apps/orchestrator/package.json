{
  "name": "codex3d-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "bun run build && electron-builder --win portable",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.codex3d.orchestrator",
    "productName": "Codex3D Orchestrator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "electron-vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "xterm": "latest",
    "xterm-addon-fit": "latest",
    "zod": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "electron": "latest",
    "electron-builder": "^26.8.1",
    "typescript": "latest"
  },
  "optionalDependencies": {
    "node-pty": "latest"
  }
}
